# Copy to `.env.local` at this repo root (gitignored). Do not put machine paths in a tracked `.env` file.
# Full template with `apps/web`: docs/ENV.local.example.md
#
# Loaded by `npm run dev` (scripts/dev-with-optional-private.mjs) and merged with apps/web/.env.local for discovery.

# Absolute or relative path to your `private_tools` clone. If unset, the launcher tries:
#   1) ./private/private-tools  (git submodule)
#   2) ../private_tools         (sibling of blackstart_tools)
# BLACKSTART_PRIVATE_TOOLS_DIR=c:\private_tools

# Set to false / 0 / no / off to only sync public assets into apps/web — do not spawn private_tools `npm run dev`.
# BLACKSTART_PRIVATE_TOOLS_AUTOSTART=false
