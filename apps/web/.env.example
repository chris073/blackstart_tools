# Copy to `.env.local` in this folder (gitignored). Do not put machine paths in tracked `.env` files.
# Full two-file walkthrough: ../../docs/ENV.local.example.md
#
# Repo-root `.env.local` can set BLACKSTART_PRIVATE_TOOLS_DIR for `npm run dev` (see repo `.env.example`).
# When private_tools is linked, the dev launcher copies its `apps/web/public` into
# `apps/web/public/private-tools-sync` and sets NEXT_PUBLIC_PRIVATE_TOOLS_PUBLIC_BASE for this process
# (you do not need to add that variable here manually).
#
# This app runs on port 3001 by default so blackstart_web can use 3000.
# Must match where FastAPI listens (see apps/api/.env.example for API_PORT).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010

# blackstart_web origin — CSP frame-ancestors so marketing can embed /tools.
NEXT_PUBLIC_MARKETING_WEB_ORIGIN=http://127.0.0.1:3000

# Optional private_tools Next app origin. Tools index links to its /tools when shown.
NEXT_PUBLIC_PRIVATE_TOOLS_WEB_ORIGIN=http://127.0.0.1:3002

# Show private companion block on /tools (default: visible). Use false / 0 / no / off to hide.
# NEXT_PUBLIC_SHOW_PRIVATE_TOOLS=false

# Markdown notes (/tools/handbook): absolute path to a folder of .md files (recursive).
# HANDBOOK_CONTENT_PATH=P:\pkm\notes
# HANDBOOK_EDITABLE=1
