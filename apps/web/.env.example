# Copy to .env.local (gitignored) to override defaults.
#
# This app runs on port 3001 by default so blackstart_web can use 3000.
# Must match where FastAPI listens (see apps/api/.env.example for API_PORT).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010

# blackstart_web origin — CSP frame-ancestors so marketing can embed /tools.
NEXT_PUBLIC_MARKETING_WEB_ORIGIN=http://127.0.0.1:3000

# private_tools Next app (Athena + handbook). Tools index links here.
NEXT_PUBLIC_PRIVATE_TOOLS_WEB_ORIGIN=http://127.0.0.1:3002
